Sub table1_KeyDown(ByVal keycode)

  If KeyDownHandler(keycode) Then Exit Sub

  If keycode = LeftFlipperKey Then lfpress = 1
  If keycode = RightFlipperKey Then rfpress = 1

  If keycode = LeftMagnaSave Then bLutActive = True
  If keycode = RightMagnaSave Then
    If bLutActive Then NextLUT: End If
    End If
    If KeyCode = PlungerKey Then Plunger.Pullback:SoundPlungerPull()

    If keycode = LeftTiltKey Then Nudge 90, 5:SoundNudgeLeft()
    If keycode = RightTiltKey Then Nudge 270, 5:SoundNudgeRight()
    If keycode = CenterTiltKey Then Nudge 0, 3:SoundNudgeCenter()

    If keycode = keyInsertCoin1 or keycode = keyInsertCoin2 or keycode = keyInsertCoin3 or keycode = keyInsertCoin4 Then
                Select Case Int(rnd*3)
                        Case 0: PlaySound ("Coin_In_1"), 0, CoinSoundLevel, 0, 0.25
                        Case 1: PlaySound ("Coin_In_2"), 0, CoinSoundLevel, 0, 0.25
                        Case 2: PlaySound ("Coin_In_3"), 0, CoinSoundLevel, 0, 0.25

    End Select

    End If

    if keycode=StartGameKey then soundStartButton()

  End Sub



 Sub table1_KeyUp(ByVal keycode)
'     If vpmKeyUp(keycode) Then Exit Sub

  If KeyUpHandler(keycode) Then Exit Sub

  If keycode = LeftFlipperKey Then
    lfpress = 0
    leftflipper.eostorqueangle = EOSA
    leftflipper.eostorque = EOST
  End If
  If keycode = RightFlipperKey Then
    rfpress = 0
    rightflipper.eostorqueangle = EOSA
    rightflipper.eostorque = EOST
  End If

    If keycode = LeftMagnaSave Then bLutActive = False

        If KeyCode = PlungerKey Then
                Plunger.Fire
                If BIPL = 1 Then
                        SoundPlungerReleaseBall()                        'Plunger release sound when there is a ball in shooter lane
                Else
                        SoundPlungerReleaseNoBall()                        'Plunger release sound when there is no ball in shooter lane
                End If
        End If


End Sub


 Function vpmKeyDown(ByVal keycode)
     On Error Resume Next ' SCoin
     vpmKeyDown = True   ' Assume we handle the key
     If keycode = RightFlipperKey Then Controller.Switch(82) = True
     If keycode = LeftFlipperKey Then Controller.Switch(84) = True
     Select Case keycode
         Case 4:vpmTimer.AddTimer 500, "vpmTimer.PulseSw 27'":Playsound SCoin
         Case 6:vpmTimer.AddTimer 500, "vpmTimer.PulseSw 28'":Playsound SCoin
         Case 2:vpmTimer.AddTimer 500, "vpmTimer.PulseSw 25'"
         Case 8:vpmTimer.AddTimer 500, "vpmTimer.PulseSw 26'"
         Case 199:vpmTimer.AddTimer 500, "vpmTimer.PulseSw 29:Drain.TimerEnabled=True'"
         Case Else vpmKeyDown = False
     End Select

     On Error Goto 0
 End Function

 Function vpmKeyUp(ByVal keycode)
     vpmKeyUp = True ' Assume we handle the key

     If keycode = RightFlipperKey Then Controller.Switch(82) = False
     If keycode = LeftFlipperKey Then Controller.Switch(84) = False
     Select Case keycode
         Case 61: Controller.Stop:Controller.Run:vpmTimer.Reset
         Case 62: Controller.LockDisplay = Not Controller.LockDisplay
         Case 63: Controller.DoubleSize = Not Controller.DoubleSize
         Case 64: If IsObject(vpmShowDips) Then Controller.Pause = True:vpmShowDips:Controller.Pause = False
         Case Else  vpmKeyUp = False
     End Select
 End Function


