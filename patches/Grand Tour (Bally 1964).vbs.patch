+  dim ratio, ax, ay
+  ax = abs(x)         'Get absolute value of each vector
+  ay = abs(y)
+  ratio = 1 / max(ax, ay)   'Create a ratio
+  ratio = ratio * (1.29289 - (ax + ay) * ratio * 0.29289)
