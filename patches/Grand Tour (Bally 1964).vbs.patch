+  If Flipper1.currentangle = Endangle1 and EOSNudge1 <> 1 Then
+    EOSNudge1 = 1
+    debug.print Flipper1.currentangle &" = "& Endangle1 &"--"& Flipper2.currentangle &" = "& EndAngle2
+    If Flipper2.currentangle = EndAngle2 Then
