+Sub InitDigits()
+  dim tmp, x, obj
+  for x = 0 to uBound(VRDigits)
+    if IsArray(VRDigits(x) ) then
+      For each obj in VRDigits(x)
+        obj.height = obj.height + 18
+        FadeDisplay obj, 0
+      next
+    end If
+  Next
+End Sub
