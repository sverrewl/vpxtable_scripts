Sub kickBall(kball, kangle, kvel, kvelz, kzlift)
  dim scat
  scat=0.2  'Increase for more saucer kicker randomness.  Random velx & vely velocity adder ranging from +-scat
  dim rangle
  rangle = 3.14 * (kangle - 90) / 180
  kball.z = kball.z + kzlift
  kball.velz = kvelz
  kball.velx = (cos(rangle)*kvel)+(((int(rnd*3))-1)*scat)
  kball.vely = (sin(rangle)*kvel)+(((int(rnd*3))-1)*scat)
End Sub


