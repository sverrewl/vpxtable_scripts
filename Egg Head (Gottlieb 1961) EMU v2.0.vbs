  if LeftSlingLight.state=1 then
    'Shadow_SlingLeft.visible=True
      AddScore(10)
  PlaySound SoundFXDOF("",103,DOFPulse,DOFContactors),0,1,-0.05,0.05
  else
      AddScore(1)
  PlaySound SoundFXDOF("SpinACard_1_10_Point_Bell",103,DOFPulse,DOFContactors),0,1,-0.05,0.05
  end if
End Sub

Sub LeftSlingShot_Timer
    Select Case LStep
        Case 3:LSLing1.Visible = 0:LSLing2.Visible = 1:sling2.TransZ = -10
        Case 4:LSLing2.Visible = 0:LSLing0.Visible = 1:sling2.TransZ = 0:LeftSlingShot.TimerEnabled = 0
    End Select
