Sub Lmag(Enabled)
  LmagEnabled = Enabled
  If Enabled Then
    If LeftMagnet.BallCntOver > 0 Then
      If MagnetBall.VelX > 0 Then MagnetBall.VelX = MagnetSpeed
    End If
' Debug.print "lmag enabled"
  End If
End Sub

Sub Cmag(Enabled)
  CmagEnabled = Enabled
  If Enabled Then
    If CenterMagnet.BallCntOver > 0 Then
      If MagnetBall.VelX > 0 Then MagnetBall.VelX = MagnetSpeed
    End If
' Debug.print "cmag enabled"
  End If
End Sub

Sub Rmag(Enabled)
  RmagEnabled = Enabled
  If Enabled Then
    If RightMagnet.BallCntOver > 0 Then
      If MagnetBall.VelX > 0 Then MagnetBall.VelX = MagnetSpeed
    End If
' Debug.print "rmag enabled"
  End If
End Sub

