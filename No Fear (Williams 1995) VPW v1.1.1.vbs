'            INIT TABLE
'************************************************************************

Dim plungerIM, kickbackIM, MagnetSpeed
Dim NFBall1, NFBall2, NFBall3, NFBall4, gBOT

Sub Table1_Init
  vpmInit Me
  With Controller
    .GameName = cGameName
    If Err Then MsgBox "Can't start Game " & cGameName & vbNewLine & Err.Description:Exit Sub
    .SplashInfoLine = "No Fear - Dangerous Sports (Williams 1995)" & vbNewLine & "VPW"
    .HandleKeyboard = 0
    .ShowTitle = 0
    .ShowDMDOnly = 1
    .ShowFrame = 0
    .HandleMechanics = 0
    .Hidden = DesktopMode 'Hide VPM DMD in Desktop Mode
    On Error Resume Next
    .Run GetPlayerHWnd
    If Err Then MsgBox Err.Description
    On Error Goto 0
    .Switch(22) = 1     'close coin door
    .Switch(24) = 1     'always closed
  End With

    ' Main Timer init
    PinMAMETimer.Interval = PinMAMEInterval
    PinMAMETimer.Enabled = 1

    ' Nudging
    vpmNudge.TiltSwitch = 14
    vpmNudge.Sensitivity = 5
    vpmNudge.TiltObj = Array(sw27, sw28)

  vpmMapLights AllLamps

    '************  Trough **************************

  Set NFBall1 = sw32.CreateSizedballWithMass(Ballsize/2,Ballmass)
  Set NFBall2 = sw33.CreateSizedballWithMass(Ballsize/2,Ballmass)
  Set NFBall3 = sw34.CreateSizedballWithMass(Ballsize/2,Ballmass)
  Set NFBall4 = sw35.CreateSizedballWithMass(Ballsize/2,Ballmass)

  gBOT = Array(NFBall1,NFBall2,NFBall3,NFBall4)

  Controller.Switch(32) = 1
  Controller.Switch(33) = 1
  Controller.Switch(34) = 1
  Controller.Switch(35) = 1

  'Add balls to shadow dictionary
  Dim xx: For Each xx in gBOT
    bsDict.Add xx.ID, bsNone
  Next

  ' Auto Plunger
  Set plungerIM = New cvpmImpulseP
  With plungerIM
    .InitImpulseP sw15, 65, 0.75
    .Switch 15
    .Random 0.05
    .CreateEvents "plungerIM"
  End With

  ' Kickback
  Set kickbackIM = New cvpmImpulseP
  With kickbackIM
    .InitImpulseP sw25, 65, 0.5
    .Random 0.05
  End With

  'Initialize slings
  RStep = 0:sw28.Timerenabled=True
  LStep = 0:sw27.Timerenabled=True

  f121.State = 0
  f128.State = 0

  Select Case StrongerMagnets
    Case 0
      MagnetSpeed = 20
    Case 1
      MagnetSpeed = 30
  End Select

End Sub

Sub Table1_Paused:  Controller.Pause = True:  End Sub
Sub Table1_unPaused:Controller.Pause = False: End Sub
Sub Table1_exit:    Controller.Pause = False:Controller.Stop: End Sub

Function Gray2RGB(gray)
  if gray < 0 then gray = 0
  if gray > 255 Then gray = 255
  Gray2RGB = RGB(gray, gray, gray)
End Function

