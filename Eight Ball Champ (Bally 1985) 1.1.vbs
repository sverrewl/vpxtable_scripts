FReturn = LeftFlipper.return
Const EOSTnew = 1 '0.8
Const EOSAnew = 1
Const EOSRampup = 0
Dim SOSRampup
Select Case FlipperCoilRampupMode
  Case 0:
    SOSRampup = 2.5
  Case 1:
    SOSRampup = 4.5
  Case 2:
    SOSRampup = 8.5
End Select
Const LiveCatch = 16
